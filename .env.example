# ─── Sporeus Athlete Console — Environment Variables ─────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.

# ── Required: Supabase ────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Optional: Sentry error monitoring ────────────────────────────────────────
# Create a project at https://sentry.io (free tier: 5k errors/month)
# Paste the DSN from: Project Settings → Client Keys (DSN)
# Also add to GitHub Actions secrets as VITE_SENTRY_DSN for production builds.
# If unset, Sentry is disabled — the app works normally.
VITE_SENTRY_DSN=

# ── Optional: Strava OAuth ────────────────────────────────────────────────────
VITE_STRAVA_CLIENT_ID=your_strava_client_id

# ── Optional: Web Push (VAPID) ────────────────────────────────────────────────
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# ── Optional: Payments ────────────────────────────────────────────────────────
VITE_DODO_CHECKOUT_COACH=
VITE_DODO_CHECKOUT_CLUB=
VITE_STRIPE_CHECKOUT_COACH=
