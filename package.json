{
  "name": "sporeus-athlete-app",
  "private": true,
  "version": "7.42.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:full": "concurrently -k -n vite,supabase,tunnel -c cyan,green,yellow \"vite --host\" \"supabase functions serve --env-file .env.local\" \"cloudflared tunnel --url http://localhost:5173\"",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "bench": "vitest bench",
    "lint": "eslint src/ --ext .js,.jsx --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed --project=chromium",
    "test:e2e:vitest": "vitest run --config vitest.e2e.config.js",
    "icons": "node scripts/generate-icons.mjs",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:ios": "npm run mobile:build && npx cap open ios",
    "mobile:android": "npm run mobile:build && npx cap open android"
  },
  "dependencies": {
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@sentry/react": "^10.49.0",
    "@supabase/supabase-js": "^2.103.0",
    "fit-file-parser": "^2.3.3",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fast-check": "^4.6.0",
    "gh-pages": "^6.2.0",
    "jsdom": "^24.1.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
